{
  "name": "4teen-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean:build-artifacts": "rm -rf .next .open-next && mkdir -p ../4teen-trash && sh -c 'for d in .next_stale_* .open-next_stale_* _hold-open-next-stale-*; do if [ -e \"$d\" ]; then mv \"$d\" ../4teen-trash/$(basename \"$d\").$(date +%s); fi; done'",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "cf:build": "pnpm run clean:build-artifacts && pnpm build && opennextjs-cloudflare build --skipNextBuild",
    "preview": "pnpm run cf:preview",
    "cf:preview": "pnpm run cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:deploy",
    "cf:deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "blog:normalize": "node scripts/blog-migration/normalize-sheet.mjs",
    "blog:fixtures": "node scripts/blog-migration/emit-db-fixtures.mjs",
    "blog:upload-media": "node scripts/blog-migration/upload-media-to-r2.mjs",
    "blog:import-db": "node scripts/blog-migration/import-db.mjs",
    "blog:daily-digest": "node scripts/blog-automation/daily-digest-runner.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@fontsource/sora": "^5.2.8",
    "@next/env": "^16.2.4",
    "cheerio": "^1.2.0",
    "lottie-react": "^2.4.1",
    "mime-types": "^3.0.2",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
