{
  "name": "4teen-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "cf:build": "rm -rf .open-next && pnpm build && opennextjs-cloudflare build --skipNextBuild",
    "preview": "pnpm run cf:preview",
    "cf:preview": "pnpm run cf:build && opennextjs-cloudflare preview",
    "deploy": "pnpm run cf:deploy",
    "cf:deploy": "pnpm run cf:build && opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@fontsource/sora": "^5.2.8",
    "lottie-react": "^2.4.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.86.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
